# Ghostty config — also read by cmux. Source: https://github.com/jiang925/install-mac/configs/ghostty.config
# ~/.config/ghostty/config

# --- Appearance ---
# You can change this to any built-in theme (e.g., tokyo-night, dracula, nord)
# theme = catppuccin-macchiato
theme = dracula
font-size = 14
window-padding-x = 10
window-padding-y = 10

# --- Window & macOS Specifics ---
# Hides the native macOS titlebar for a seamless, borderless look (perfect for tmux)
# macos-titlebar-style = hidden
# Essential for terminal developers on Mac to use standard shell/tmux shortcuts
macos-option-as-alt = true
# Closes the application completely when you close the last window
quit-after-last-window-closed = true

# --- Behavior ---
# Automatically copies text to the clipboard when you highlight it
copy-on-select = clipboard
# Silences the terminal bell
cursor-style = block
cursor-style-blink = false

# --- Keybindings ---
# Line start/end (Ctrl+A / Ctrl+E)
keybind = cmd+left=text:\x01
keybind = cmd+right=text:\x05
# Tab switching (top bar) — matches browser cmd+opt+arrows
keybind = cmd+alt+left=previous_tab
keybind = cmd+alt+right=next_tab
# Split/window switching (sidebar)
keybind = cmd+alt+up=goto_split:previous
keybind = cmd+alt+down=goto_split:next
keybind = shift+enter=text:\n

# --- Scrollback ---
# 100MB scrollback buffer (lazy-allocated, won't use memory until filled)
scrollback-limit = 200000000

# --- Compatibility ---
# Keep xterm-ghostty locally (better feature detection), SSH handled via ~/.ssh/config
